{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/lifecycle",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/lifecycle",
      "destination": "/api/cron/lifecycle"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
