# App
APP_NAME=invest-control-bot
APP_ENV=local
APP_RUNTIME=server

# HTTP
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s

# Logging
# Supported values: debug, info, warn, error
# Daily rotated files will be created in this directory using this base name,
# for example logs/app-2026-04-08.log.
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# PostgreSQL
# Optional: set DB_DSN (or DATABASE_URL) to use a full ready-made connection string.
DB_DSN=
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=amp_affiliate
DB_CHARSET=utf8
DB_COLLATION=utf8_unicode_ci
DB_SSL=disable
DB_WITH_MIGRATION=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=investcontrolgeneral_bot
# Optional emergency override for Telegram Bot API outbound traffic.
# Use this when the hosting network can serve the app normally but cannot reach
# https://api.telegram.org directly (for example due to regional routing issues,
# provider filtering, or selective Telegram blocking). In that case the app can
# talk to a trusted external relay such as a Cloudflare Worker instead of
# calling Telegram API directly from the VPS.
# Example:
# TELEGRAM_API_BASE_URL=https://telegram-bot-relay.example.workers.dev
# Leave empty during normal operation.
TELEGRAM_API_BASE_URL=
# Optional HTTP/HTTPS proxy for Telegram Bot API requests. This is an
# alternative to TELEGRAM_API_BASE_URL when you already have a trusted outbound
# proxy and do not want to run a separate Bot API relay endpoint.
TELEGRAM_HTTP_PROXY_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PUBLIC_URL=https://example.com/telegram/webhook

# MAX
# MAX webhook delivery is handled by cmd/server.
MAX_BOT_TOKEN=
MAX_BOT_NAME=
MAX_BOT_USERNAME=
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_PUBLIC_URL=https://example.com/max/webhook

# Yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# Payment (temporary)
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_BASE_URL=https://example.com

# Robokassa
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=
ROBOKASSA_IS_TEST_MODE=true
ROBOKASSA_RECURRING_ENABLED=false
ROBOKASSA_CHECKOUT_URL=https://auth.robokassa.ru/Merchant/Index.aspx
ROBOKASSA_REBILL_URL=https://auth.robokassa.ru/Merchant/Recurring

# Security
APP_ENCRYPTION_KEY=replace-with-32-or-more-char-secret
# For local development can be empty; for stage/prod must be set.
ADMIN_AUTH_TOKEN=replace-with-strong-admin-token
