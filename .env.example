# App
APP_NAME=invest-control-bot
APP_ENV=local
APP_RUNTIME=server

# HTTP
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s

# Logging
# Supported values: debug, info, warn, error
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# PostgreSQL
# Optional: set DB_DSN (or DATABASE_URL) to use a full ready-made connection string.
DB_DSN=
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=amp_affiliate
DB_CHARSET=utf8
DB_COLLATION=utf8_unicode_ci
DB_SSL=disable
DB_WITH_MIGRATION=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=investcontrolgeneral_bot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PUBLIC_URL=https://example.com/telegram/webhook

# MAX
# MAX webhook delivery is handled by cmd/server.
MAX_BOT_TOKEN=
MAX_BOT_NAME=
MAX_BOT_USERNAME=
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_PUBLIC_URL=https://example.com/max/webhook

# Yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# Payment (temporary)
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_BASE_URL=https://example.com

# Robokassa
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=
ROBOKASSA_IS_TEST_MODE=true
ROBOKASSA_RECURRING_ENABLED=false
ROBOKASSA_CHECKOUT_URL=https://auth.robokassa.ru/Merchant/Index.aspx
ROBOKASSA_REBILL_URL=https://auth.robokassa.ru/Merchant/Recurring

# Security
APP_ENCRYPTION_KEY=replace-with-32-or-more-char-secret
# For local development can be empty; for stage/prod must be set.
ADMIN_AUTH_TOKEN=replace-with-strong-admin-token
